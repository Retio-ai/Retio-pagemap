# Hardened multi-stage container for PageMap
# Based on python:slim with security hardening (non-root, minimal attack surface)

ARG PAGEMAP_VERSION=0.0.0

# ── Stage 1: Build ────────────────────────────────────────────────────
FROM python:3.14-slim-bookworm AS builder

ARG PAGEMAP_VERSION
COPY --from=ghcr.io/astral-sh/uv:0.8 /uv /usr/local/bin/uv

RUN uv venv /opt/pagemap && \
    uv pip install --python /opt/pagemap/bin/python \
        "retio-pagemap==${PAGEMAP_VERSION}"

# Install Playwright Chromium
ENV PATH="/opt/pagemap/bin:$PATH"
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers
RUN playwright install --with-deps chromium

# ── Stage 2: Runtime ─────────────────────────────────────────────────
FROM python:3.14-slim-bookworm

ARG PAGEMAP_VERSION=0.0.0

# OCI image labels
LABEL org.opencontainers.image.title="PageMap" \
      org.opencontainers.image.description="MCP server for efficient web page interaction — compressed, actionable page maps for AI agents" \
      org.opencontainers.image.version="${PAGEMAP_VERSION}" \
      org.opencontainers.image.vendor="Retio AI" \
      org.opencontainers.image.url="https://github.com/Retio-ai/pagemap" \
      org.opencontainers.image.source="https://github.com/Retio-ai/pagemap" \
      org.opencontainers.image.documentation="https://github.com/Retio-ai/pagemap#readme" \
      org.opencontainers.image.licenses="AGPL-3.0-only" \
      io.retio.security.hardened="true"

# Copy runtime deps from builder
COPY --from=builder /opt/pagemap /opt/pagemap
COPY --from=builder /opt/pw-browsers /opt/pw-browsers

# Install Chromium runtime dependencies only (no dev packages)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        libnss3 libnspr4 libdbus-1-3 libatk1.0-0 libatk-bridge2.0-0 \
        libcups2 libdrm2 libxkbcommon0 libatspi2.0-0 libxcomposite1 \
        libxdamage1 libxfixes3 libxrandr2 libgbm1 libpango-1.0-0 \
        libcairo2 libasound2 libwayland-client0 && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

ENV PATH="/opt/pagemap/bin:$PATH"
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PAGEMAP_CONTAINER_MODE=1

# Non-root user for security
RUN groupadd -r pagemap && useradd -r -g pagemap -m pagemap && \
    chown -R pagemap:pagemap /opt/pw-browsers
USER pagemap
WORKDIR /home/pagemap

# MCP Registry ownership verification
LABEL io.modelcontextprotocol.server.name="io.github.Retio-ai/pagemap"

EXPOSE 8080
STOPSIGNAL SIGTERM

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/health')"

ENTRYPOINT ["retio-pagemap"]
CMD ["--transport", "streamable-http", "--port", "8080"]
